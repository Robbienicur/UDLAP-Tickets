# Copiar este archivo como .env y ajustar valores en cada entorno.
# El archivo .env nunca se commitea (revisa .gitignore).

# Llave secreta de Django. Generar una nueva por entorno con:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=cambia-esta-llave-en-cada-entorno

# Modo debug. true solo para desarrollo, false en produccion.
DJANGO_DEBUG=true

# Hosts permitidos separados por coma. En produccion poner el dominio real.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Origenes CORS permitidos separados por coma. Sin wildcard en produccion.
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:8001,http://127.0.0.1:8001

# TTL del codigo de recuperacion de contrasena en segundos.
PASSWORD_RESET_CODE_TTL=600
